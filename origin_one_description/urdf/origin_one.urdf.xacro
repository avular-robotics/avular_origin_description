<?xml version='1.0'?>

<!-- Parametric description for the Avular Origin One. -->
<robot name="avular_origin_one" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="drive_configuration" default="skid_steer_drive"/>

  <!-- Per-robot link/joint prefix (empty = none). -->
  <xacro:arg name="prefix" default=""/>
  <xacro:property name="prefix" value="$(arg prefix)"/>
  <xacro:property name="P" value="${prefix + ('_' if prefix else '')}"/>

  <xacro:property name="var" value="$(arg drive_configuration)"/>
  <xacro:if value="${var == 'skid_steer_drive'}">
    <xacro:property name="trackWidth" value="0.500"/>
    <xacro:property name="wheelbase" value="0.410"/>
    <xacro:property name="wheelRadius" value="0.120"/>
    <xacro:property name="groundClearance" value="0.064"/>
    <xacro:property name="wheelMeshFileA" value="package://origin_one_description/urdf/meshes/wheel.obj"/>
    <xacro:property name="wheelMeshFileB" value="package://origin_one_description/urdf/meshes/wheel.obj"/>
  </xacro:if>
  <xacro:if value="${var == 'big_skid_steer_drive' or var == 'elevated_skid_steer_drive'}">
    <xacro:property name="trackWidth" value="0.530"/>
    <xacro:property name="wheelbase" value="0.410"/>
    <xacro:property name="wheelRadius" value="0.165"/>
    <xacro:property name="groundClearance" value="0.109"/>
    <xacro:property name="wheelMeshFileA" value="package://origin_one_description/urdf/meshes/wheel_big.obj"/>
    <xacro:property name="wheelMeshFileB" value="package://origin_one_description/urdf/meshes/wheel_big.obj"/>
  </xacro:if>
  <xacro:if value="${var == 'mecanum_drive'}">
    <xacro:property name="trackWidth" value="0.475"/>
    <xacro:property name="wheelbase" value="0.410"/>
    <xacro:property name="wheelRadius" value="0.1015"/>
    <xacro:property name="groundClearance" value="0.0455"/>
    <xacro:property name="wheelMeshFileA" value="package://origin_one_description/urdf/meshes/wheel_mecanumA.obj"/>
    <xacro:property name="wheelMeshFileB" value="package://origin_one_description/urdf/meshes/wheel_mecanumB.obj"/>
  </xacro:if>

  <xacro:macro name="wheel_link" params="name visual_rpy mesh">
    <link name="${P}${name}">
      <inertial>
        <mass value="1"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
      <collision>
        <origin xyz="0 0 0.0" rpy="0 0 0"/>
        <geometry>
          <cylinder length=".07" radius="${wheelRadius}"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="${visual_rpy}"/>
        <geometry>
          <mesh filename="${mesh}"
            scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
    </link>
  </xacro:macro>

  <xacro:macro name="wheel_joint" params="name xyz">
    <joint type="continuous" name="${P}main_body_${name}">
      <origin xyz="${xyz}" rpy="-1.5707 0 0"/>
      <child link="${P}${name}" />
      <parent link="${P}main_body"/>
      <axis xyz="0 0 1"/>
      <limit effort="100000.0" velocity="10"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="us_link" params="name">
    <link name="${P}us_${name}_link"/>
  </xacro:macro>

  <xacro:macro name="us_joint" params="name xyz rpy">
    <joint type="fixed" name="${P}us_${name}_joint">
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <child link="${P}us_${name}_link"/>
      <parent link="${P}main_body"/>
    </joint>
  </xacro:macro>

  <link name='${P}base_link' />

  <link name='${P}main_body'>
    <inertial>
      <mass value="21.0"/>
      <inertia ixx="0.4" ixy="0.0" ixz="0.0" iyy="0.77" iyz="0.0" izz="1.01"/>
    </inertial>
    <collision name='collision'>
      <origin xyz="0 0 0.07" rpy="0 0 0.0"/>
      <geometry>
        <box size=".65 .4 .125"/>
      </geometry>
    </collision>
    <visual name='visual'>
      <origin xyz="0 0 0" rpy="0 0 0.0"/>
      <geometry>
        <mesh filename="package://origin_one_description/urdf/meshes/body.obj"
          scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
  </link>

  <xacro:wheel_link name="left_front_wheel"  visual_rpy="0.0 1.5707 0.0"  mesh="${wheelMeshFileA}"/>
  <xacro:wheel_link name="right_front_wheel" visual_rpy="0.0 -1.5707 0.0" mesh="${wheelMeshFileB}"/>
  <xacro:wheel_link name="left_rear_wheel"   visual_rpy="0.0 1.5707 0.0"  mesh="${wheelMeshFileB}"/>
  <xacro:wheel_link name="right_rear_wheel"  visual_rpy="0.0 -1.5707 0.0" mesh="${wheelMeshFileA}"/>


  <link name="${P}ouster_base">
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual name="visual">
      <geometry>
        <mesh filename="package://origin_one_description/urdf/meshes/ouster.obj"
          scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
    <collision name="collision-base">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <link name="${P}os_sensor" />

  <link name="${P}camera_link">
    <inertial>
      <mass value="0.035"/>
      <inertia ixx="0.001" ixy="0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <collision name="collision">
      <origin xyz="0 0.047 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.13 0.022"/>
      </geometry>
    </collision>
  </link>

  <link name="${P}gnss_link">
    <visual name="visual_pole">
      <geometry>
        <mesh filename="package://origin_one_description/urdf/meshes/antenna.obj"
          scale="0.001 0.001 0.001" />
      </geometry>
      <origin xyz="0.0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.1"/>
      </geometry>
    </visual>
  </link>

  <xacro:us_link name="left_front"/>
  <xacro:us_link name="center_front"/>
  <xacro:us_link name="right_front"/>
  <xacro:us_link name="left_rear"/>
  <xacro:us_link name="center_rear"/>
  <xacro:us_link name="right_rear"/>

  <link name="${P}imu_link"/>

  <joint type="fixed" name="${P}base_body">
    <origin xyz="0.0 0 ${groundClearance}" rpy="0 0 0"/>
    <child link="${P}main_body" />
    <parent link="${P}base_link"/>
  </joint>

  <xacro:wheel_joint name="left_front_wheel"  xyz="${wheelbase/2} ${trackWidth/2} 0.056"/>
  <xacro:wheel_joint name="right_front_wheel" xyz="${wheelbase/2} ${-trackWidth/2} 0.056"/>
  <xacro:wheel_joint name="left_rear_wheel"   xyz="${-wheelbase/2} ${trackWidth/2} 0.056"/>
  <xacro:wheel_joint name="right_rear_wheel"  xyz="${-wheelbase/2} ${-trackWidth/2} 0.056"/>

  <joint type="fixed" name="${P}ouster_platform_joint">
    <origin xyz="0.272 0 0.189" rpy="0 0 0"/>
    <child link="${P}ouster_base" />
    <parent link="${P}main_body"/>
  </joint>

  <joint name="${P}ouster_orientation_joint" type="fixed">
    <parent link="${P}ouster_base" />
    <child link="${P}os_sensor" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint type="fixed" name="${P}realsense_joint">
    <origin xyz="0.3156 0.017 0.096" rpy="0 0 0"/>
    <child link="${P}camera_link"/>
    <parent link="${P}main_body"/>
  </joint>

  <joint type="fixed" name="${P}gnss_joint">
    <origin xyz="-0.0505 0 0.212" rpy="0 0 0"/>
    <child link="${P}gnss_link"/>
    <parent link="${P}main_body"/>
  </joint>

  <xacro:us_joint name="left_front"   xyz="0.314 0.119 0.072"   rpy="0 0 -0.7854"/>
  <xacro:us_joint name="center_front" xyz="0.322 0 0.063"       rpy="0 0 0"/>
  <xacro:us_joint name="right_front"  xyz="0.314 -0.119 0.072"  rpy="0 0 0.7854"/>
  <xacro:us_joint name="left_rear"    xyz="-0.314 0.119 0.072"  rpy="0 0 -2.357"/>
  <xacro:us_joint name="center_rear"  xyz="-0.322 0 0.063"      rpy="0 0 3.1416"/>
  <xacro:us_joint name="right_rear"   xyz="-0.314 -0.119 0.072" rpy="0 0 2.357"/>

  <joint type="fixed" name="${P}imu_joint">
    <origin xyz="-0.1266 0.0749 0.066" rpy="0 0 2.357"/>
    <child link="${P}imu_link"/>
    <parent link="${P}main_body"/>
  </joint>

</robot>